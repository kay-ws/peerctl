#!/bin/bash

set -euo pipefail

PEERCTL_HOME="${PEERCTL_HOME:-${XDG_RUNTIME_DIR:-/tmp}/peerctl}"
PEERCTL_TMUX_SESSION="${PEERCTL_TMUX_SESSION:-peers}"
PEERCTL_AGENT="${PEERCTL_AGENT:-claude}"
PEERCTL_SPAWN_WAIT="${PEERCTL_SPAWN_WAIT:-1}"   # 0 で spawn の ready 待ちを無効（テスト用）

die() { printf 'peerctl: %s\n' "$*" >&2; exit 1; }

peer_dir() { printf '%s/peers/%s\n' "$PEERCTL_HOME" "$1"; }

# 指定 peerdir の signal に書き込む on-stop スクリプト本体を出力
render_hook() {
  local pd="$1"
  cat <<EOF
#!/bin/bash

input=\$(cat)
sid=\$(printf '%s' "\$input" | jq -r '.session_id // ""')
tp=\$(printf '%s' "\$input" | jq -r '.transcript_path // ""')
lam=\$(printf '%s' "\$input" | jq -r '.last_assistant_message // ""')
printf '%s\t%s\t%s\t%s\n' "\$(date +%s)" "\$sid" "\$tp" "\$lam" > "$pd/signal"
exit 0
EOF
}

# workdir の .claude/settings.local.json に自分の Stop hook を「マージ」で足す。
# 既存ファイルは壊さず（不正 JSON なら die）、自分のエントリだけ追加する。
# kill の後始末判断のため created_file/created_dir を meta に記録する。
install_hook() {
  local workdir="$1" pd="$2"
  mkdir -p "$pd"
  render_hook "$pd" > "$pd/on-stop.sh"
  chmod +x "$pd/on-stop.sh"

  local cmd_path="$pd/on-stop.sh"
  local claude_dir="$workdir/.claude"
  local settings="$claude_dir/settings.local.json"
  local created_dir=0 created_file=0 base_json

  if [[ -f "$settings" ]]; then
    jq -e . "$settings" >/dev/null 2>&1 \
      || die "install: $settings は不正な JSON です。修正するか削除してから再実行してください"
    base_json="$(cat "$settings")"
  else
    created_file=1
    base_json='{}'
  fi

  [[ -d "$claude_dir" ]] || created_dir=1
  mkdir -p "$claude_dir"

  local tmp; tmp="$(mktemp)"
  jq --arg cmd "$cmd_path" \
    '.hooks.Stop = ((.hooks.Stop // []) + [{hooks:[{type:"command",command:$cmd}]}])' \
    <<<"$base_json" > "$tmp" \
    || { rm -f "$tmp"; die "install: $settings へのマージに失敗しました"; }
  mv "$tmp" "$settings"

  meta_set "$pd" hook_created_file "$created_file"
  meta_set "$pd" hook_created_dir "$created_dir"
}

# install_hook が足した自分の Stop hook エントリだけを撤去する。command パス
# （peer 固有の on-stop.sh）をマーカーに使うので、同じ dir に複数 peer が居ても
# 自分のぶんだけ消える。外部要因で不正 JSON 化していたら触らない。自分で作った
# ファイル/.claude は（中身が空になったら）削除する。
uninstall_hook() {
  local workdir="$1" pd="$2"
  local settings="$workdir/.claude/settings.local.json"
  [[ -f "$settings" ]] || return 0
  jq -e . "$settings" >/dev/null 2>&1 || {
    printf 'peerctl: warning: %s は不正な JSON のため hook を撤去せず残します\n' "$settings" >&2
    return 0
  }

  local cmd_path="$pd/on-stop.sh"
  local created_file created_dir
  created_file="$(meta_get "$pd" hook_created_file)"
  created_dir="$(meta_get "$pd" hook_created_dir)"

  local tmp; tmp="$(mktemp)"
  jq --arg cmd "$cmd_path" '
    .hooks.Stop = ((.hooks.Stop // []) | map(select(
      ([.hooks[]?.command] | any(. == $cmd)) | not
    )))
    | if (.hooks.Stop // []) == [] then del(.hooks.Stop) else . end
    | if (.hooks // {}) == {} then del(.hooks) else . end
  ' "$settings" > "$tmp" || { rm -f "$tmp"; return 0; }

  if [[ "$created_file" == "1" && "$(cat "$tmp")" == "{}" ]]; then
    rm -f "$settings" "$tmp"
    [[ "$created_dir" == "1" ]] && rmdir "$workdir/.claude" 2>/dev/null || true
  else
    mv "$tmp" "$settings"
  fi
}

# meta は key=value 行。値は read で安全に取り出す（source しない）
meta_set() {
  local pd="$1" key="$2" val="$3"
  mkdir -p "$pd"
  local tmp; tmp="$(mktemp)"
  { grep -v "^${key}=" "$pd/meta" 2>/dev/null || true; printf '%s=%s\n' "$key" "$val"; } > "$tmp"
  mv "$tmp" "$pd/meta"
}
meta_get() {
  local pd="$1" key="$2"
  [[ -f "$pd/meta" ]] || { printf ''; return 0; }
  local line; line="$(grep "^${key}=" "$pd/meta" | tail -1)"
  printf '%s' "${line#*=}"
}

read_signal_epoch() {
  local pd="$1"
  [[ -f "$pd/signal" ]] || { printf '0'; return 0; }
  cut -f1 "$pd/signal"
}
read_signal_field() {
  local pd="$1" n="$2"
  [[ -f "$pd/signal" ]] || { printf ''; return 0; }
  cut -f"$n" "$pd/signal"
}

# 最終 user 行より後ろの assistant テキストを連結して返す
extract_last_reply() {
  local file="$1"
  jq -rs '
    (map(.message.role // .type) | rindex("user")) as $u
    | if $u == null then "" else
        .[($u+1):]
        | map(select((.message.role // "") == "assistant") | .message.content)
        | map(if type == "array" then (map(select(.type == "text") | .text) | join("\n"))
              elif type == "string" then .
              else "" end)
        | map(select(. != ""))
        | join("\n")
      end
  ' "$file"
}

usage() {
  cat <<'EOF'
peerctl - orchestrate Claude Code peers over tmux

usage:
  peerctl spawn  <name> [--base <ref>] [--no-git] [--dir <path>]
  peerctl ensure <name> [--base <ref>] [--no-git] [--dir <path>]
  peerctl send  <name> <message...>
  peerctl recv  <name> [--timeout <seconds>]
  peerctl ask   <name> <message...> [--timeout <seconds>]
  peerctl list
  peerctl kill  <name> [--keep-worktree]
EOF
}

_ensure_session() {
  tmux has-session -t "$PEERCTL_TMUX_SESSION" 2>/dev/null \
    || tmux new-session -d -s "$PEERCTL_TMUX_SESSION" -n __scratch
}

# claude TUI が prompt を受け付けられる状態になるまで待つ。
# 起動直後に出うる 2 つのゲートを通過させてから ready を待つ:
#   1. PEERCTL_AGENT に --dangerously-skip-permissions を付けた場合の
#      "Bypass Permissions mode" 警告画面（既定 "1. No, exit" → Down で
#      "2. Yes, I accept" に移して Enter 確定）。
#   2. 新規 dir 初回の「このフォルダを信頼する?」ダイアログ（Enter で承認）。
# capture-pane の条件ポーリングで、固定 sleep に頼らない。
_wait_ready() {
  local target="$1" timeout="${2:-30}"
  local deadline=$(( $(date +%s) + timeout )) pane trusted=0 accepted=0
  while [[ $(date +%s) -lt $deadline ]]; do
    pane="$(tmux capture-pane -p -t "$target" 2>/dev/null || true)"
    if [[ $accepted -lt 2 && "$pane" == *"Bypass Permissions mode"* ]]; then
      # Down→Enter の 2 キーをループの別イテレーションに分けて送る。
      # back-to-back 送信だと Enter が Down より先に処理され、既定の
      # "1. No, exit" を誤確定して claude が落ちうるため。
      if [[ $accepted -eq 0 ]]; then
        tmux send-keys -t "$target" Down
        accepted=1
      else
        tmux send-keys -t "$target" Enter
        accepted=2
      fi
    elif [[ $trusted -eq 0 && "$pane" == *"trust this folder"* ]]; then
      tmux send-keys -t "$target" Enter
      trusted=1
    elif [[ "$pane" == *"Context:"* || "$pane" == *"Welcome"* ]]; then
      return 0
    fi
    sleep 0.5
  done
  return 1
}

cmd_spawn() {
  local name="" base="HEAD" nogit=0 dir=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --base) base="$2"; shift 2 ;;
      --no-git) nogit=1; shift ;;
      --dir) dir="$2"; shift 2 ;;
      -*) die "spawn: unknown option $1" ;;
      *) [[ -z "$name" ]] && name="$1" || die "spawn: extra arg $1"; shift ;;
    esac
  done
  [[ -n "$name" ]] || die "spawn: name required"
  local pd; pd="$(peer_dir "$name")"
  [[ -e "$pd/meta" ]] && die "spawn: peer '$name' already exists"

  local workdir branch=""
  if [[ -n "$dir" ]]; then
    workdir="$dir"; mkdir -p "$workdir"
  elif [[ $nogit -eq 1 ]]; then
    workdir="$(mktemp -d "${TMPDIR:-/tmp}/peer-$name.XXXX")"
  else
    git rev-parse --is-inside-work-tree >/dev/null 2>&1 || die "spawn: not in a git repo (use --no-git or --dir)"
    branch="peer/$name"
    workdir="$(git rev-parse --show-toplevel)/.peers/$name"
    git worktree add -b "$branch" "$workdir" "$base" >/dev/null
  fi

  mkdir -p "$pd"
  install_hook "$workdir" "$pd"
  meta_set "$pd" target "$PEERCTL_TMUX_SESSION:$name"
  meta_set "$pd" workdir "$workdir"
  meta_set "$pd" branch "$branch"

  _ensure_session
  tmux new-window -t "$PEERCTL_TMUX_SESSION" -n "$name" -c "$workdir"
  tmux send-keys -t "$PEERCTL_TMUX_SESSION:$name" -l -- "$PEERCTL_AGENT"
  tmux send-keys -t "$PEERCTL_TMUX_SESSION:$name" Enter

  if [[ "$PEERCTL_SPAWN_WAIT" == "1" ]]; then
    _wait_ready "$PEERCTL_TMUX_SESSION:$name" 30 \
      || die "spawn: peer '$name' did not reach a ready prompt (agent failed to start?)"
  fi
  printf 'spawned peer %s (workdir: %s)\n' "$name" "$workdir"
}

# spawn の冪等版: peer が既にあれば no-op、無ければ元の引数で spawn にパススルー
cmd_ensure() {
  local -a rest=("$@")
  local name=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --base|--dir) shift 2 ;;
      --no-git) shift ;;
      -*) die "ensure: unknown option $1" ;;
      *) if [[ -z "$name" ]]; then name="$1"; fi; shift ;;
    esac
  done
  [[ -n "$name" ]] || die "ensure: name required"
  local pd; pd="$(peer_dir "$name")"
  if [[ -e "$pd/meta" ]]; then
    printf 'peer %s already exists\n' "$name"
    return 0
  fi
  cmd_spawn "${rest[@]}"
}

cmd_list() {
  local base="$PEERCTL_HOME/peers"
  [[ -d "$base" ]] || { echo "(no peers)"; return 0; }
  local pd name target sig last status
  for pd in "$base"/*/; do
    [[ -d "$pd" ]] || continue
    name="$(basename "$pd")"
    target="$(meta_get "$pd" target)"
    sig="$(read_signal_epoch "$pd")"
    last="$(cat "$pd/last_send" 2>/dev/null || echo 0)"
    if [[ "$last" -gt "$sig" ]]; then
      local elapsed=$(( $(date +%s) - last ))
      status="working(${elapsed}s)"
    elif [[ "$sig" -gt 0 ]]; then
      local lam; lam="$(read_signal_field "$pd" 4)"
      status="done: \"${lam:0:30}\""
    else
      status="idle"
    fi
    printf '%-16s %-20s %s\n' "$name" "$target" "$status"
  done
}

cmd_kill() {
  local name="" keep=0
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --keep-worktree) keep=1; shift ;;
      *) [[ -z "$name" ]] && name="$1" || die "kill: extra arg $1"; shift ;;
    esac
  done
  [[ -n "$name" ]] || die "kill: name required"
  local pd; pd="$(peer_dir "$name")"
  local target workdir branch
  target="$(meta_get "$pd" target)"; workdir="$(meta_get "$pd" workdir)"; branch="$(meta_get "$pd" branch)"
  [[ -n "$target" ]] && tmux kill-window -t "$target" 2>/dev/null || true
  if [[ $keep -eq 0 && -n "$branch" && -n "$workdir" ]]; then
    git worktree remove --force "$workdir" 2>/dev/null || true
  fi
  [[ -n "$workdir" ]] && uninstall_hook "$workdir" "$pd" || true
  rm -rf "$pd"
  printf 'killed peer %s\n' "$name"
}

cmd_send() {
  local name="${1:-}"; shift || true
  [[ -n "$name" ]] || die "send: name required"
  local msg="$*"
  [[ -n "$msg" ]] || die "send: message required"
  local pd; pd="$(peer_dir "$name")"
  local target; target="$(meta_get "$pd" target)"
  [[ -n "$target" ]] || die "send: unknown peer '$name'"
  date +%s > "$pd/last_send"
  # 改行を空白化 → 本文(リテラル, Enter なし) → 独立 Enter の 2 段送信
  local oneline="${msg//$'\n'/ }"
  tmux send-keys -t "$target" -l -- "$oneline"
  tmux send-keys -t "$target" Enter
}

cmd_recv() {
  local name="" timeout=120
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --timeout) timeout="$2"; shift 2 ;;
      *) [[ -z "$name" ]] && name="$1" || die "recv: extra arg $1"; shift ;;
    esac
  done
  [[ -n "$name" ]] || die "recv: name required"
  local pd; pd="$(peer_dir "$name")"
  [[ -f "$pd/meta" ]] || die "recv: unknown peer '$name'"
  local since; since="$(cat "$pd/last_send" 2>/dev/null || echo 0)"
  local deadline=$(( $(date +%s) + timeout ))
  while [[ $(date +%s) -lt $deadline ]]; do
    local sig; sig="$(read_signal_epoch "$pd")"
    if [[ "$sig" -gt "$since" ]]; then
      local tp; tp="$(read_signal_field "$pd" 3)"
      [[ -f "$tp" ]] && { extract_last_reply "$tp"; return 0; }
    fi
    sleep 0.3
  done
  die "recv: timeout waiting for '$name' (peer may still be working)"
}

cmd_ask() {
  local name="${1:-}"; shift || true
  [[ -n "$name" ]] || die "ask: name required"
  local timeout=120 args=()
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --timeout) timeout="$2"; shift 2 ;;
      *) args+=("$1"); shift ;;
    esac
  done
  cmd_send "$name" "${args[@]}"
  cmd_recv "$name" --timeout "$timeout"
}

main() {
  local cmd="${1:-}"; shift || true
  case "$cmd" in
    spawn) cmd_spawn "$@" ;;
    ensure) cmd_ensure "$@" ;;
    send)  cmd_send "$@" ;;
    recv)  cmd_recv "$@" ;;
    ask)   cmd_ask "$@" ;;
    list)  cmd_list "$@" ;;
    kill)  cmd_kill "$@" ;;
    ""|-h|--help|help) usage ;;
    *) usage >&2; die "unknown command: $cmd" ;;
  esac
}

if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
  main "$@"
fi
